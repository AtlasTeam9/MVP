root = true

# Regole generali per tutti i file
[*]
indent_style = space
indent_size = 4
end_of_line = lf
charset = utf-8
trim_trailing_whitespace = true
insert_final_newline = true
max_line_length = 100

# Frontend: JavaScript, TypeScript, JSX, TSX, CSS, JSON
[*.{js,ts,jsx,tsx,css,json}]
indent_size = 4

# YAML e file di configurazione
[*.{yml,yaml}]
indent_size = 2

# Markdown
[*.md]
trim_trailing_whitespace = false
